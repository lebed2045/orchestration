# Claude Code orchestration temp files (generated during workflow)
.claude/temp/
!.claude/temp/.gitkeep

# Claude research outputs
.claude/research/

# Codex workflow artifacts
codex/temp/

# Local settings
.claude/settings.local.json

# Reflections are machine-local (live in ~/.claude/reflections/), never in the repo
.claude/reflections/

# Antigravity CLI local project symlinks (per-machine, points into ~/.gemini/config)
.antigravitycli/

# Python bytecode (hook + test helpers)
__pycache__/
*.pyc
