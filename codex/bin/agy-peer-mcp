#!/usr/bin/env python3
"""Local MCP bridge: Antigravity first, google300 Vertex fallback second."""

from __future__ import annotations

import argparse
import json
import os
import shutil
import subprocess
import sys
import urllib.error
import urllib.request


SERVER_VERSION = "1.1.0"
AGY_BIN = os.environ.get("AGY_BIN", "agy")
AGY_MODEL = os.environ.get("AGY_MODEL", "Gemini 3.5 Flash (High)")
PROXY_BASE = os.environ.get("AGY_FALLBACK_BASE_URL", "http://127.0.0.1:8300").rstrip("/")
PROXY_MODEL = os.environ.get("AGY_FALLBACK_MODEL", "gemini-3.5-flash")
DEFAULT_TIMEOUT = float(os.environ.get("AGY_TIMEOUT_S", "180"))


class GeminiUnavailableError(RuntimeError):
    """Neither the Antigravity primary nor the configured fallback answered."""


TOOLS = [
    {
        "name": "agy_ask",
        "description": (
            "Ask Gemini for an independent second opinion. Uses Antigravity (agy) first "
            "and the local google300 Vertex proxy only when agy is unavailable."
        ),
        "inputSchema": {
            "type": "object",
            "properties": {
                "prompt": {"type": "string"},
                "timeout_s": {"type": "number", "minimum": 1},
            },
            "required": ["prompt"],
        },
    },
    {
        "name": "agy_continue",
        "description": "Continue the most recent agy conversation, with stateless Vertex fallback.",
        "inputSchema": {
            "type": "object",
            "properties": {
                "prompt": {"type": "string"},
                "timeout_s": {"type": "number", "minimum": 1},
            },
            "required": ["prompt"],
        },
    },
    {
        "name": "agy_status",
        "description": "Check the agy primary route and google300 fallback without spending quota.",
        "inputSchema": {"type": "object", "properties": {}},
    },
]


def _run_agy(prompt: str, timeout_s: float, *, continuation: bool = False) -> tuple[bool, str]:
    if not shutil.which(AGY_BIN):
        return False, f"agy executable not found: {AGY_BIN}"
    args = [AGY_BIN]
    if continuation:
        args.append("--continue")
    args.extend(["--model", AGY_MODEL, "--print", prompt, "--print-timeout", f"{int(timeout_s)}s"])
    try:
        proc = subprocess.run(
            args,
            stdin=subprocess.DEVNULL,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
            timeout=timeout_s + 10,
            check=False,
        )
    except subprocess.TimeoutExpired:
        return False, f"agy timed out after {timeout_s:g}s"
    except OSError as exc:
        return False, f"agy could not start: {exc}"

    output = proc.stdout.strip()
    if proc.returncode == 0 and output:
        return True, output
    detail = proc.stderr.strip() or output or "agy returned an empty response"
    return False, detail[-2000:]


def _proxy_json(path: str, *, body: dict | None = None, timeout_s: float = 10) -> dict:
    data = json.dumps(body).encode() if body is not None else None
    request = urllib.request.Request(
        f"{PROXY_BASE}{path}",
        data=data,
        headers={"Content-Type": "application/json"},
        method="POST" if data is not None else "GET",
    )
    with urllib.request.urlopen(request, timeout=timeout_s) as response:
        return json.loads(response.read())


def _run_proxy(prompt: str, timeout_s: float, primary_error: str) -> str:
    try:
        response = _proxy_json(
            f"/v1beta/models/{PROXY_MODEL}:generateContent?key=agy",
            body={"contents": [{"role": "user", "parts": [{"text": prompt}]}]},
            timeout_s=timeout_s,
        )
        candidates = response.get("candidates") or []
        parts = candidates[0].get("content", {}).get("parts", []) if candidates else []
        text = "\n".join(part.get("text", "") for part in parts if part.get("text")).strip()
        if not text:
            raise RuntimeError("google300 returned no text candidate")
    except (OSError, ValueError, KeyError, IndexError, RuntimeError) as exc:
        raise GeminiUnavailableError(
            f"agy failed ({primary_error}); google300 failed ({exc})"
        ) from exc
    return (
        f"[agy unavailable — routed to google300 Vertex/{PROXY_MODEL}; "
        f"primary error: {primary_error}]\n\n{text}"
    )


def ask(prompt: str, timeout_s: float, *, continuation: bool = False) -> str:
    review_prompt = (
        "Act as an independent read-only reviewer. Do not edit files, create files, or run "
        "destructive commands. Challenge assumptions and return a second opinion.\n\n" + prompt
    )
    ok, result = _run_agy(review_prompt, timeout_s, continuation=continuation)
    if ok:
        return f"[route: agy / {AGY_MODEL}]\n\n{result}"
    fallback_prompt = review_prompt
    if continuation:
        fallback_prompt = (
            "This is a continuation request, but the primary conversation is unavailable. "
            "Answer independently from the supplied prompt:\n\n" + review_prompt
        )
    return _run_proxy(fallback_prompt, timeout_s, result)


def status() -> str:
    agy_ok = False
    agy_detail = f"not found ({AGY_BIN})"
    if shutil.which(AGY_BIN):
        try:
            proc = subprocess.run(
                [AGY_BIN, "models"],
                stdin=subprocess.DEVNULL,
                stdout=subprocess.PIPE,
                stderr=subprocess.PIPE,
                text=True,
                timeout=15,
                check=False,
            )
            agy_ok = proc.returncode == 0 and AGY_MODEL in proc.stdout
            agy_detail = f"model available: {AGY_MODEL}" if agy_ok else (proc.stderr.strip() or "model unavailable")
        except (OSError, subprocess.TimeoutExpired) as exc:
            agy_detail = str(exc)

    proxy_ok = False
    proxy_detail = "unreachable"
    try:
        health = _proxy_json("/healthz", timeout_s=3)
        models = _proxy_json("/v1beta/models", timeout_s=3).get("models", [])
        names = {model.get("name", "").removeprefix("models/") for model in models}
        proxy_ok = bool(health.get("ok")) and PROXY_MODEL in names
        proxy_detail = f"{health.get('project')} / {health.get('location')} / {PROXY_MODEL}"
    except (OSError, ValueError) as exc:
        proxy_detail = str(exc)

    overall = "ready" if agy_ok or proxy_ok else "unavailable"
    return (
        f"agy bridge {SERVER_VERSION}: {overall}\n"
        f"primary agy: {'ok' if agy_ok else 'failed'} — {agy_detail}\n"
        f"fallback google300: {'ok' if proxy_ok else 'failed'} — {proxy_detail}"
    )


def _response(request: dict) -> dict | None:
    method = request.get("method")
    request_id = request.get("id")
    if method == "notifications/initialized":
        return None
    if method == "initialize":
        return {
            "jsonrpc": "2.0",
            "id": request_id,
            "result": {
                "protocolVersion": request.get("params", {}).get("protocolVersion", "2024-11-05"),
                "capabilities": {"tools": {}},
                "serverInfo": {"name": "agy", "version": SERVER_VERSION},
            },
        }
    if method == "ping":
        return {"jsonrpc": "2.0", "id": request_id, "result": {}}
    if method == "tools/list":
        return {"jsonrpc": "2.0", "id": request_id, "result": {"tools": TOOLS}}
    if method == "tools/call":
        params = request.get("params", {})
        arguments = params.get("arguments", {})
        name = params.get("name")
        timeout_s = float(arguments.get("timeout_s", DEFAULT_TIMEOUT))
        try:
            if name == "agy_ask":
                text = ask(str(arguments.get("prompt", "")), timeout_s)
            elif name == "agy_continue":
                text = ask(str(arguments.get("prompt", "")), timeout_s, continuation=True)
            elif name == "agy_status":
                text = status()
            else:
                return {"jsonrpc": "2.0", "id": request_id, "error": {"code": -32601, "message": f"unknown tool: {name}"}}
        except GeminiUnavailableError as exc:
            return {
                "jsonrpc": "2.0",
                "id": request_id,
                "error": {"code": -32000, "message": f"GEMINI_UNAVAILABLE: {exc}"},
            }
        return {
            "jsonrpc": "2.0",
            "id": request_id,
            "result": {"content": [{"type": "text", "text": text}]},
        }
    return {"jsonrpc": "2.0", "id": request_id, "error": {"code": -32601, "message": f"unknown method: {method}"}}


def _cli(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(
        prog="agy-ask",
        description="Ask Gemini through the Antigravity-first, Vertex-fallback router.",
    )
    subparsers = parser.add_subparsers(dest="command", required=True)

    for command in ("ask", "continue"):
        command_parser = subparsers.add_parser(command)
        command_parser.add_argument(
            "prompt",
            nargs="*",
            help="Prompt text. Reads stdin when omitted or when the prompt is '-'.",
        )
        command_parser.add_argument("--timeout", type=float, default=DEFAULT_TIMEOUT)
    subparsers.add_parser("status")

    args = parser.parse_args(argv)
    if args.command == "status":
        print(status())
        return 0

    prompt_parts = args.prompt
    prompt = sys.stdin.read().strip() if not prompt_parts or prompt_parts == ["-"] else " ".join(prompt_parts).strip()
    if not prompt:
        parser.error("a non-empty prompt is required")

    try:
        print(ask(prompt, args.timeout, continuation=args.command == "continue"))
    except GeminiUnavailableError as exc:
        print(f"GEMINI_UNAVAILABLE: {exc}", file=sys.stderr)
        return 1
    return 0


def main() -> int:
    argv = sys.argv[1:]
    if os.path.basename(sys.argv[0]) == "agy-ask":
        if argv == ["--status"]:
            argv = ["status"]
        elif not argv or argv[0] not in {"ask", "continue", "status"}:
            argv = ["ask", *argv]
    if argv:
        return _cli(argv)

    for line in sys.stdin:
        try:
            request = json.loads(line)
            response = _response(request)
            if response is not None:
                print(json.dumps(response), flush=True)
        except Exception as exc:
            print(json.dumps({"jsonrpc": "2.0", "id": None, "error": {"code": -32603, "message": str(exc)}}), flush=True)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
